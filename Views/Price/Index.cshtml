@model IOCLCommunityHall.Models.ViewModels.PriceViewModel
@{
    ViewData["Title"] = "Price & Rate Management";
}

<div class="row">
    <!-- Price Update Form (Left) -->
    <div class="col-lg-5">
        <div class="card iocl-card shadow-sm">
            <div class="card-header iocl-card-header text-white" style="background-color: var(--iocl-orange);">
                <h5 class="mb-0"><i class="bi bi-tags-fill me-2"></i>Update Rental Item Price</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="UpdatePrice" method="post" id="priceUpdateForm">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="ItemId" class="form-label iocl-form-label">Select Inventory Item</label>
                        <select asp-for="ItemId" class="form-select iocl-form-control" id="selectItemPrice" required>
                            <option value="">-- Choose Item --</option>
                            @foreach (var item in Model.AllItems)
                            {
                                <option value="@item.Id" data-price="@item.CurrentPrice">@item.Name (Current: ₹@item.CurrentPrice/@item.UnitType)</option>
                            }
                        </select>
                        <span asp-validation-for="ItemId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label iocl-form-label d-block text-muted">Current Base Price: <span class="fw-bold text-dark fs-5 ms-1" id="currentPriceVal">₹0.00</span></label>
                        <input type="hidden" asp-for="CurrentPrice" id="inputCurrentPrice" />
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="NewPrice" class="form-label iocl-form-label"></label>
                            <input asp-for="NewPrice" type="number" step="0.01" class="form-control iocl-form-control" required />
                            <span asp-validation-for="NewPrice" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EffectiveDate" class="form-label iocl-form-label"></label>
                            <input asp-for="EffectiveDate" type="date" class="form-control iocl-form-control" required />
                            <span asp-validation-for="EffectiveDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Reason" class="form-label iocl-form-label"></label>
                        <textarea asp-for="Reason" class="form-control iocl-form-control" rows="3" placeholder="Provide justification (e.g. Approved by GM HR, General inflation adjustment...)" required></textarea>
                        <span asp-validation-for="Reason" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-check-square-fill me-2"></i>Apply Price Update
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Pricing Audit Trail summary & Navigation (Right) -->
    <div class="col-lg-7">
        <div class="card iocl-card shadow-sm h-100">
            <div class="card-header iocl-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-clock-history me-2 text-primary"></i>Recent Pricing Audit Trail</span>
                <a asp-action="History" class="btn btn-sm btn-outline-primary border-0 fw-bold">Full Audit Logs</a>
            </div>
            <div class="card-body p-4 text-center d-flex flex-column justify-content-center">
                <i class="bi bi-shield-check-fill text-success fs-1 mb-3"></i>
                <h5 class="fw-bold text-dark">Price History is Permanent</h5>
                <p class="text-muted small px-lg-4">In compliance with PSU auditing guidelines, item rental prices are never deleted. All historic prices, change reasons, and authorizing officers are kept permanently in the audit archives.</p>
                <div class="mt-3">
                    <a asp-action="History" class="btn btn-iocl-blue px-4"><i class="bi bi-journal-text me-1"></i>Open History Log</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#selectItemPrice').on('change', function () {
                var selected = $(this).find('option:selected');
                var price = selected.data('price') || 0;
                $('#currentPriceVal').text('₹' + Number(price).toFixed(2));
                $('#inputCurrentPrice').val(price);
            });
        });
    </script>
}
