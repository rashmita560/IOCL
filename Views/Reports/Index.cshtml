@model IOCLCommunityHall.Models.ViewModels.ReportViewModel
@{
    ViewData["Title"] = "Reports & Analytics Center";
    var showResults = Model != null;
    var hasData = Model != null && Model.TotalRentals > 0;
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card iocl-card shadow-sm">
            <div class="card-header iocl-card-header text-white" style="background-color: var(--iocl-blue);">
                <h5 class="mb-0"><i class="bi bi-file-earmark-bar-graph-fill me-2"></i>Generate Township Activity Report</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Generate" method="post" id="reportFilterForm">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label iocl-form-label">Report Type</label>
                            <select asp-for="ReportType" class="form-select iocl-form-control" id="selectReportType">
                                <option value="0">Monthly Report</option>
                                <option value="1">Yearly Report</option>
                                <option value="2">Custom Date Range</option>
                                <option value="3">Lifetime Report</option>
                            </select>
                        </div>
                        
                        <!-- Month Picker -->
                        <div class="col-md-3 filter-monthly">
                            <label class="form-label iocl-form-label">Select Month</label>
                            <select asp-for="SelectedMonth" class="form-select iocl-form-control">
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m">@System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(m)</option>
                                }
                            </select>
                        </div>

                        <!-- Year Picker -->
                        <div class="col-md-2 filter-monthly filter-yearly">
                            <label class="form-label iocl-form-label">Select Year</label>
                            <select asp-for="SelectedYear" class="form-select iocl-form-control">
                                @for (int y = DateTime.Today.Year; y >= 2022; y--)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>

                        <!-- Date range pickers -->
                        <div class="col-md-3 filter-custom d-none">
                            <label class="form-label iocl-form-label">Start Date</label>
                            <input asp-for="StartDate" type="date" class="form-control iocl-form-control" />
                        </div>
                        <div class="col-md-3 filter-custom d-none">
                            <label class="form-label iocl-form-label">End Date</label>
                            <input asp-for="EndDate" type="date" class="form-control iocl-form-control" />
                        </div>

                        <div class="col-md-4 d-flex align-items-end gap-2">
                            <button type="submit" class="btn btn-primary flex-grow-1"><i class="bi bi-search me-1"></i>Generate</button>
                            @if (hasData)
                            {
                                <a href="@Url.Action("ExportCsv", new { reportType = Model.ReportType, startDate = Model.StartDate, endDate = Model.EndDate, selectedYear = Model.SelectedYear, selectedMonth = Model.SelectedMonth })" class="btn btn-outline-primary"><i class="bi bi-filetype-csv"></i></a>
                                <a href="@Url.Action("ExportExcel", new { reportType = Model.ReportType, startDate = Model.StartDate, endDate = Model.EndDate, selectedYear = Model.SelectedYear, selectedMonth = Model.SelectedMonth })" class="btn btn-outline-success"><i class="bi bi-file-earmark-excel"></i></a>
                            }
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@if (Model != null)
{
    <!-- Report Summary Widgets -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card p-3 border shadow-sm">
                <span class="text-muted small text-uppercase fw-bold">Grand Total Revenue</span>
                <h3 class="fw-bold text-primary mb-0">₹@Model.TotalRevenue.ToString("N2")</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 border shadow-sm">
                <span class="text-muted small text-uppercase fw-bold">Approved Rentals</span>
                <h3 class="fw-bold text-success mb-0">@Model.TotalRentals</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 border shadow-sm">
                <span class="text-muted small text-uppercase fw-bold">Pending/Rejected Ratio</span>
                <h3 class="fw-bold text-warning mb-0">@Model.PendingCount / @Model.RejectedCount</h3>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Most Used Items -->
        <div class="col-md-12">
            <div class="card iocl-card shadow-sm h-100">
                <div class="card-header iocl-card-header"><i class="bi bi-box-seam me-2"></i>Most Rented Inventory Items</div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Item Name</th>
                                <th class="text-center">Total Quantity Rented</th>
                                <th class="text-end">Revenue Generated</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.MostUsedItems != null && Model.MostUsedItems.Any())
                            {
                                foreach (var item in Model.MostUsedItems)
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold">@item.ItemName</td>
                                        <td class="text-center">@item.TotalQuantityRented</td>
                                        <td class="text-end fw-bold text-primary">₹@item.TotalRevenue.ToString("N2")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="3" class="text-center py-4 text-muted">No rental logs found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            function toggleFields() {
                var val = $('#selectReportType').val();
                if (val == "0") { // Monthly
                    $('.filter-monthly').removeClass('d-none');
                    $('.filter-yearly').removeClass('d-none');
                    $('.filter-custom').addClass('d-none');
                } else if (val == "1") { // Yearly
                    $('.filter-monthly').addClass('d-none');
                    $('.filter-yearly').removeClass('d-none');
                    $('.filter-custom').addClass('d-none');
                } else if (val == "2") { // Custom Range
                    $('.filter-monthly').addClass('d-none');
                    $('.filter-yearly').addClass('d-none');
                    $('.filter-custom').removeClass('d-none');
                } else { // Lifetime
                    $('.filter-monthly').addClass('d-none');
                    $('.filter-yearly').addClass('d-none');
                    $('.filter-custom').addClass('d-none');
                }
            }

            $('#selectReportType').on('change', toggleFields);
            toggleFields(); // run initial
        });
    </script>
}
