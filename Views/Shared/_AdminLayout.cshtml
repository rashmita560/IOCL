@using Microsoft.AspNetCore.Identity
@inject SignInManager<IOCLCommunityHall.Models.Entities.ApplicationUser> SignInManager
@inject UserManager<IOCLCommunityHall.Models.Entities.ApplicationUser> UserManager
@{
    var currentUser = await UserManager.GetUserAsync(User);
    var unreadCount = ViewBag.UnreadNotifications ?? 0;
    var isSuperAdmin = User.IsInRole("SuperAdmin");
    var isHOD = User.IsInRole("HOD");
    var isGM = User.IsInRole("GM");
    var isApprover = isSuperAdmin || isHOD || isGM;
    var roleLabel = isSuperAdmin ? "Super Admin" : isGM ? "General Manager" : isHOD ? "Head of Dept" : "Employee";
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – IOCL Community Hall Management</title>
    <meta name="description" content="IOCL Panipat Refinery Township Community Hall Rental Management System" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/iocl.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="iocl-layout">

    <!-- ═══════════════════════════════ TOP HEADER ═══════════════════════════════ -->
    <header class="iocl-header bg-white shadow-sm py-2 px-4 d-flex justify-content-between align-items-center">
        <!-- Logo -->
        <div class="iocl-brand d-flex align-items-center gap-2">
            <a href="/" class="iocl-logo-link">
                <img src="https://iocl.com/assets/images/logo.gif" alt="IOCL Logo" style="height: 48px; object-fit: contain;" onerror="this.src='/images/iocl-logo.png'" />
            </a>
            <div class="iocl-app-title ms-2">
                <div class="iocl-org-name font-bold text-uppercase" style="font-size: 0.72rem; letter-spacing: 0.8px; font-weight: 700; color: #003399;">Indian Oil Corporation Limited</div>
                <div class="iocl-portal-name font-black text-dark" style="font-size: 1.05rem; font-weight: 800; color: #1e293b; letter-spacing: -0.2px;">Community Hall & Inventory Portal</div>
            </div>
        </div>

        <!-- Right: Social, Notification, Profile -->
        <div class="iocl-header-controls d-flex align-items-center gap-3">
            <!-- Social Media Icons -->
            <div class="social-icons d-none d-lg-flex gap-1 me-3">
                <a href="https://facebook.com" target="_blank" class="social-icon facebook"><i class="bi bi-facebook"></i></a>
                <a href="https://twitter.com" target="_blank" class="social-icon twitter"><i class="bi bi-twitter-x"></i></a>
                <a href="https://youtube.com" target="_blank" class="social-icon youtube"><i class="bi bi-youtube"></i></a>
                <a href="https://instagram.com" target="_blank" class="social-icon instagram"><i class="bi bi-instagram"></i></a>
                <a href="https://linkedin.com" target="_blank" class="social-icon linkedin"><i class="bi bi-linkedin"></i></a>
            </div>

            <!-- Notification Bell -->
            <div class="dropdown">
                <button class="btn iocl-icon-btn position-relative" data-bs-toggle="dropdown" id="notifBellBtn" style="border: 1px solid #e2e8f0; border-radius: 50%; width: 38px; height: 38px; display: inline-flex; align-items: center; justify-content: center; background-color: #f8fafc; color: #64748b; padding: 0;">
                    <i class="bi bi-bell-fill"></i>
                    @if (unreadCount > 0)
                    {
                        <span class="notification-badge" style="position: absolute; top: -3px; right: -3px; background: linear-gradient(135deg, #FF6600, #FF8C42); color: #FFFFFF; font-size: 0.62rem; font-weight: 700; padding: 0.1rem 0.3rem; border-radius: 10px; border: 2px solid #FFFFFF;">@(unreadCount > 99 ? "99+" : unreadCount.ToString())</span>
                    }
                </button>
                <div class="dropdown-menu dropdown-menu-end notif-dropdown" style="min-width:320px">
                    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                        <strong>Notifications</strong>
                        <a asp-controller="Notification" asp-action="MarkAllRead" class="btn btn-sm btn-link text-decoration-none">Mark all read</a>
                    </div>
                    <partial name="_Notifications" model="@(ViewBag.RecentNotifications as IEnumerable<IOCLCommunityHall.Models.Entities.Notification> ?? new List<IOCLCommunityHall.Models.Entities.Notification>())" />
                    <div class="text-center py-2 border-top">
                        <a asp-controller="Notification" asp-action="Index" class="btn btn-sm text-primary text-decoration-none fw-bold">View All</a>
                    </div>
                </div>
            </div>

            <!-- User Dropdown -->
            <div class="dropdown">
                <button class="btn dropdown-toggle border-0 p-0 bg-transparent d-flex align-items-center gap-2" data-bs-toggle="dropdown" style="color: inherit; box-shadow: none;">
                    <div class="text-end d-none d-md-block" style="line-height: 1.25;">
                        <div class="fw-bold text-dark" style="font-size: 0.85rem;">@currentUser?.FullName</div>
                        <div class="text-muted text-uppercase" style="font-size: 0.68rem; font-weight: 600; letter-spacing: 0.3px;">@roleLabel</div>
                    </div>
                    <div class="iocl-avatar" style="background-color: #0c1b3e; color: #FFFFFF; width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; border: 2px solid #e2e8f0; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                        @(currentUser?.FullName?.Substring(0, 1).ToUpper() ?? "U")
                    </div>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><h6 class="dropdown-header">@currentUser?.Email</h6></li>
                    <li><span class="dropdown-item-text text-muted small">@currentUser?.Department</span></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item" href="/Account/ChangePassword">
                            <i class="bi bi-shield-lock me-2"></i>Change Password
                        </a>
                    </li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </header>

    <!-- ═══════════════════════════════ TOP NAVIGATION BAR ═══════════════════════════════ -->
    <nav class="navbar navbar-expand-lg navbar-dark iocl-navbar">
        <div class="container-fluid">
            <!-- Mobile Toggle -->
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#ioclNavbarContent" aria-controls="ioclNavbarContent" aria-expanded="false" aria-label="Toggle navigation" style="padding: 0.25rem 0.5rem;">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="ioclNavbarContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
                    @if (isSuperAdmin)
                    {
                        <li class="nav-item">
                            <a asp-controller="AdminDashboard" asp-action="Index" class="nav-link px-3 py-2 text-white @(controller == "AdminDashboard" ? "active-link" : "")">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="AdminRequest" asp-action="Index" class="nav-link px-3 py-2 text-white @(controller == "AdminRequest" ? "active-link" : "")">
                                <i class="bi bi-file-earmark-text me-1"></i>Rental Requests
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle px-3 py-2 text-white @((controller == "Inventory" || controller == "Price") ? "active-link" : "")" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-boxes me-1"></i>Inventory
                            </a>
                            <ul class="dropdown-menu">
                                <li><a asp-controller="Inventory" asp-action="Index" class="dropdown-item"><i class="bi bi-box me-2"></i>Inventory Items</a></li>
                                <li><a asp-controller="Price" asp-action="Index" class="dropdown-item"><i class="bi bi-currency-rupee me-2"></i>Price Management</a></li>
                                <li><a asp-controller="Price" asp-action="History" class="dropdown-item"><i class="bi bi-clock-history me-2"></i>Price History</a></li>
                            </ul>
                        </li>
                        @* Hide Analytics dropdown from frontend UI
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle px-3 py-2 text-white @((controller == "Reports" || controller == "Audit") ? "active-link" : "")" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-bar-chart-line me-1"></i>Analytics
                            </a>
                            <ul class="dropdown-menu">
                                <li><a asp-controller="Reports" asp-action="Index" class="dropdown-item"><i class="bi bi-graph-up me-2"></i>Reports &amp; Analytics</a></li>
                                <li><a asp-controller="Audit" asp-action="Index" class="dropdown-item"><i class="bi bi-journal-text me-2"></i>Audit Logs</a></li>
                            </ul>
                        </li>
                        *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle px-3 py-2 text-white @(controller == "SuperAdmin" ? "active-link" : "")" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-shield-lock me-1"></i>Super Admin
                            </a>
                            <ul class="dropdown-menu">
                                <li><a asp-controller="SuperAdmin" asp-action="Users" class="dropdown-item"><i class="bi bi-people me-2"></i>User Accounts</a></li>
                            </ul>
                        </li>
                        @* SuperAdmin self-booking links *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle px-3 py-2 text-white @(controller == "RentalRequest" ? "active-link" : "")" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-cart-plus me-1"></i>My Rentals
                            </a>
                            <ul class="dropdown-menu">
                                <li><a asp-controller="RentalRequest" asp-action="Create" class="dropdown-item"><i class="bi bi-plus-circle me-2"></i>New Rental Request</a></li>
                                <li><a asp-controller="RentalRequest" asp-action="MyRequests" class="dropdown-item"><i class="bi bi-card-list me-2"></i>My Requests</a></li>
                            </ul>
                        </li>
                    }
                    else if (isHOD || isGM)
                    {
                        @* HOD / GM — approver panel + self-booking *@
                        <li class="nav-item">
                            <a asp-controller="AdminRequest" asp-action="Index" class="nav-link px-3 py-2 text-white @(controller == "AdminRequest" ? "active-link" : "")">
                                <i class="bi bi-file-earmark-check me-1"></i>Approvals
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle px-3 py-2 text-white @(controller == "RentalRequest" ? "active-link" : "")" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-cart-plus me-1"></i>Rentals
                            </a>
                            <ul class="dropdown-menu">
                                <li><a asp-controller="RentalRequest" asp-action="Create" class="dropdown-item"><i class="bi bi-plus-circle me-2"></i>New Rental Request</a></li>
                                <li><a asp-controller="RentalRequest" asp-action="MyRequests" class="dropdown-item"><i class="bi bi-card-list me-2"></i>My Requests</a></li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Notification" asp-action="Index" class="nav-link px-3 py-2 text-white @(controller == "Notification" ? "active-link" : "")">
                                <i class="bi bi-bell-fill me-1"></i>Notifications
                            </a>
                        </li>
                    }
                    else
                    {
                        @* Regular Employee *@
                        <li class="nav-item">
                            <a asp-controller="UserDashboard" asp-action="Index" class="nav-link px-3 py-2 text-white @(controller == "UserDashboard" ? "active-link" : "")">
                                <i class="bi bi-grid-1x2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle px-3 py-2 text-white @(controller == "RentalRequest" ? "active-link" : "")" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-cart-plus me-1"></i>Rentals
                            </a>
                            <ul class="dropdown-menu">
                                <li><a asp-controller="RentalRequest" asp-action="Create" class="dropdown-item"><i class="bi bi-plus-circle me-2"></i>New Rental Request</a></li>
                                <li><a asp-controller="RentalRequest" asp-action="MyRequests" class="dropdown-item"><i class="bi bi-card-list me-2"></i>My Requests</a></li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Notification" asp-action="Index" class="nav-link px-3 py-2 text-white @(controller == "Notification" ? "active-link" : "")">
                                <i class="bi bi-bell-fill me-1"></i>Notifications
                            </a>
                        </li>
                    }
                </ul>
                
                <div class="d-none d-lg-flex align-items-center gap-3">
                    <span class="text-uppercase fw-bold" style="color: #FF8C42; font-size: 0.85rem; letter-spacing: 1px;">PANIPAT REFINERY</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-link px-3 py-1 text-white text-decoration-none d-flex align-items-center gap-1 nav-exit-btn" style="font-size: 0.9rem; font-weight: 600;">
                            <i class="bi bi-box-arrow-right"></i>Exit
                        </button>
                    </form>
                </div>
                
                <!-- Mobile Exit/Refinery -->
                <div class="d-lg-none mt-3 pt-3 border-top d-flex justify-content-between align-items-center">
                    <span class="text-uppercase fw-bold" style="color: #FF8C42; font-size: 0.85rem; letter-spacing: 1px;">PANIPAT REFINERY</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-danger btn-sm px-3 fw-bold d-flex align-items-center gap-1">
                            <i class="bi bi-box-arrow-right"></i>Exit
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <div class="iocl-page-wrapper">

        <!-- ═══════════════════════════════ MAIN CONTENT ════════════════════════ -->
        <main class="iocl-main-content">
            <!-- Breadcrumb / Page Title -->
            @if (ViewData["PageTitle"] != null)
            {
                <div class="iocl-page-header">
                    <div>
                        <h1 class="iocl-page-title">@ViewData["PageTitle"]</h1>
                        @if (ViewData["Breadcrumb"] != null)
                        {
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb iocl-breadcrumb mb-0">
                                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-fill"></i></a></li>
                                    @Html.Raw(ViewData["Breadcrumb"].ToString())
                                </ol>
                            </nav>
                        }
                    </div>
                    @if (ViewData["HeaderAction"] != null)
                    {
                        <div>@Html.Raw(ViewData["HeaderAction"].ToString())</div>
                    }
                </div>
            }

            <!-- Toast Alerts -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible iocl-alert fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible iocl-alert fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <!-- ═══════════════════════════════ FOOTER ══════════════════════════════════ -->
    <footer class="iocl-footer">
        <div class="container-fluid">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <span>Developed for <strong>IOCL Panipat Refinery Township</strong></span>
                </div>
                <div class="col-md-6 text-center text-md-end text-muted small">
                    &copy; @DateTime.Now.Year Indian Oil Corporation Limited. All rights reserved.
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="~/js/iocl.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
