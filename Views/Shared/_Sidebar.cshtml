@{
    var isSuperAdmin = User.IsInRole("SuperAdmin");
    var isHOD = User.IsInRole("HOD");
    var isGM = User.IsInRole("GM");
    var isApprover = isSuperAdmin || isHOD || isGM;
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

@if (isApprover)
{
    <!-- APPROVER SIDEBAR (SuperAdmin / GM / HOD) -->
    <div class="sidebar-header d-flex justify-content-between align-items-center">
        <span class="sidebar-section-label">
            @if (isSuperAdmin) { <text>ADMIN PANEL</text> }
            else if (isGM) { <text>GM PANEL</text> }
            else { <text>HOD PANEL</text> }
        </span>
        <button type="button" class="btn btn-link text-white p-0 sidebar-collapse-btn" aria-label="Collapse sidebar">
            <i class="bi bi-chevron-left" style="font-size: 1.2rem; color: rgba(255,255,255,0.75);"></i>
        </button>
    </div>
    <ul class="sidebar-nav">
        @if (isSuperAdmin)
        {
            <li class="nav-item @(controller == "AdminDashboard" ? "active" : "")">
                <a asp-controller="AdminDashboard" asp-action="Index" class="nav-link">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
            </li>
        }
        <li class="sidebar-section-label-item">APPROVALS</li>
        <li class="nav-item @(controller == "AdminRequest" && action == "Index" ? "active" : "")">
            <a asp-controller="AdminRequest" asp-action="Index" class="nav-link">
                <i class="bi bi-file-earmark-check"></i>
                <span>Rental Requests</span>
                <span class="badge bg-warning ms-auto" id="pendingBadge"></span>
            </a>
        </li>

        @if (isSuperAdmin)
        {

            <li class="sidebar-section-label-item">INVENTORY</li>
            <li class="nav-item @(controller == "Inventory" ? "active" : "")">
                <a asp-controller="Inventory" asp-action="Index" class="nav-link">
                    <i class="bi bi-boxes"></i>
                    <span>Inventory Items</span>
                </a>
            </li>
            <li class="nav-item @(controller == "Price" && action == "Index" ? "active" : "")">
                <a asp-controller="Price" asp-action="Index" class="nav-link">
                    <i class="bi bi-currency-rupee"></i>
                    <span>Price Management</span>
                </a>
            </li>
            <li class="nav-item @(controller == "Price" && action == "History" ? "active" : "")">
                <a asp-controller="Price" asp-action="History" class="nav-link">
                    <i class="bi bi-clock-history"></i>
                    <span>Price History</span>
                </a>
            </li>
            @* Hide Analytics sidebar items from frontend UI
            <li class="sidebar-section-label-item">ANALYTICS</li>
            <li class="nav-item @(controller == "Reports" ? "active" : "")">
                <a asp-controller="Reports" asp-action="Index" class="nav-link">
                    <i class="bi bi-bar-chart-line"></i>
                    <span>Reports & Analytics</span>
                </a>
            </li>
            <li class="nav-item @(controller == "Audit" ? "active" : "")">
                <a asp-controller="Audit" asp-action="Index" class="nav-link">
                    <i class="bi bi-journal-text"></i>
                    <span>Audit Logs</span>
                </a>
            </li>
            *@
            <li class="sidebar-section-label-item">SUPER ADMIN</li>
            <li class="nav-item @(controller == "SuperAdmin" ? "active" : "")">
                <a asp-controller="SuperAdmin" asp-action="Users" class="nav-link">
                    <i class="bi bi-people"></i>
                    <span>User Management</span>
                </a>
            </li>

        }

        <!-- All approvers (HOD/GM/SuperAdmin) can also self-book -->
        <li class="sidebar-section-label-item">MY BOOKINGS</li>
        <li class="nav-item @(controller == "UserDashboard" ? "active" : "")">
            <a asp-controller="UserDashboard" asp-action="Index" class="nav-link">
                <i class="bi bi-grid-1x2"></i>
                <span>User Dashboard</span>
            </a>
        </li>
        <li class="nav-item @(controller == "RentalRequest" && action == "Create" ? "active" : "")">
            <a asp-controller="RentalRequest" asp-action="Create" class="nav-link">
                <i class="bi bi-plus-circle"></i>
                <span>New Rental Request</span>
            </a>
        </li>
        <li class="nav-item @(controller == "RentalRequest" && action == "MyRequests" ? "active" : "")">
            <a asp-controller="RentalRequest" asp-action="MyRequests" class="nav-link">
                <i class="bi bi-card-list"></i>
                <span>My Requests</span>
            </a>
        </li>

        <li class="nav-item @(controller == "Notification" ? "active" : "")">
            <a asp-controller="Notification" asp-action="Index" class="nav-link">
                <i class="bi bi-bell"></i>
                <span>Notifications</span>
            </a>
        </li>
    </ul>
}
else
{
    <!-- USER SIDEBAR (Employee) -->
    <div class="sidebar-header d-flex justify-content-between align-items-center">
        <span class="sidebar-section-label">USER PORTAL</span>
        <button type="button" class="btn btn-link text-white p-0 sidebar-collapse-btn" aria-label="Collapse sidebar">
            <i class="bi bi-chevron-left" style="font-size: 1.2rem; color: rgba(255,255,255,0.75);"></i>
        </button>
    </div>
    <ul class="sidebar-nav">
        <li class="nav-item @(controller == "UserDashboard" ? "active" : "")">
            <a asp-controller="UserDashboard" asp-action="Index" class="nav-link">
                <i class="bi bi-grid-1x2"></i>
                <span>Dashboard</span>
            </a>
        </li>
        <li class="sidebar-section-label-item">RENTALS</li>
        <li class="nav-item @(controller == "RentalRequest" && action == "Create" ? "active" : "")">
            <a asp-controller="RentalRequest" asp-action="Create" class="nav-link">
                <i class="bi bi-plus-circle"></i>
                <span>New Rental Request</span>
            </a>
        </li>
        <li class="nav-item @(controller == "RentalRequest" && action == "MyRequests" ? "active" : "")">
            <a asp-controller="RentalRequest" asp-action="MyRequests" class="nav-link">
                <i class="bi bi-card-list"></i>
                <span>My Requests</span>
            </a>
        </li>

        <li class="sidebar-section-label-item">ALERTS</li>
        <li class="nav-item @(controller == "Notification" ? "active" : "")">
            <a asp-controller="Notification" asp-action="Index" class="nav-link">
                <i class="bi bi-bell"></i>
                <span>Notifications</span>
            </a>
        </li>
    </ul>
}
