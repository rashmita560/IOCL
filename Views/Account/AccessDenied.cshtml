@{
    Layout = "_Layout";
    ViewData["Title"] = "Access Denied";
}

<div class="container text-center py-5" style="margin-top: 100px;">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 p-5" style="border-top: 5px solid var(--color-danger) !important;">
                <div class="text-danger mb-4">
                    <i class="bi bi-shield-fill-x" style="font-size: 5rem;"></i>
                </div>
                <h2 class="fw-bold text-dark">Access Denied</h2>
                <p class="text-muted mt-3">You do not have the required permissions to view this resource. This portal is restricted to authorized IOCL Panipat Township officials.</p>
                <div class="mt-4">
                    <a href="/" class="btn btn-primary px-4 py-2">
                        <i class="bi bi-house-door-fill me-2"></i>Go to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
