@model IOCLCommunityHall.Models.ViewModels.HallViewModel
@using IOCLCommunityHall.Models.Entities
@{
    ViewData["Title"] = "Edit Facility";
    ViewData["PageTitle"] = "Edit Facility";
    ViewData["Breadcrumb"] = "<li class=\"breadcrumb-item\"><a href=\"/Facility/Index\">Facilities</a></li><li class=\"breadcrumb-item active\">Edit</li>";
}

<div class="row">
    <div class="col-lg-8">
        <div class="card iocl-card shadow-sm">
            <div class="card-header iocl-card-header bg-white border-bottom">
                <span class="fw-bold text-dark">
                    <i class="bi bi-pencil-fill me-2 text-primary"></i>Edit Facility – @Model.Name
                </span>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="ImagePath" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <div class="row mb-3">
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label iocl-form-label"></label>
                            <input asp-for="Name" class="form-control iocl-form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FacilityType" class="form-label iocl-form-label"></label>
                            <select asp-for="FacilityType" class="form-select iocl-form-control"
                                    asp-items="Html.GetEnumSelectList<IOCLCommunityHall.Models.Entities.FacilityType>()">
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label iocl-form-label"></label>
                        <textarea asp-for="Description" class="form-control iocl-form-control" rows="2"></textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-8">
                            <label asp-for="Location" class="form-label iocl-form-label"></label>
                            <input asp-for="Location" class="form-control iocl-form-control" />
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Capacity" class="form-label iocl-form-label"></label>
                            <input asp-for="Capacity" type="number" class="form-control iocl-form-control" min="1" />
                            <span asp-validation-for="Capacity" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Facilities" class="form-label iocl-form-label"></label>
                        <input asp-for="Facilities" class="form-control iocl-form-control" />
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="RentalRatePerDay" class="form-label iocl-form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                <input asp-for="RentalRatePerDay" type="number" class="form-control iocl-form-control" step="100" min="0" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label iocl-form-label"></label>
                            <select asp-for="Status" class="form-select iocl-form-control"
                                    asp-items="Html.GetEnumSelectList<IOCLCommunityHall.Models.Entities.HallStatus>()">
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DisplayOrder" class="form-label iocl-form-label"></label>
                            <input asp-for="DisplayOrder" type="number" class="form-control iocl-form-control" min="0" />
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div class="mb-3">
                            <label class="form-label iocl-form-label">Current Image</label>
                            <div>
                                <img src="@Model.ImagePath" alt="Current facility image"
                                     style="height:100px; border-radius:8px; object-fit:cover;" />
                            </div>
                        </div>
                    }

                    <div class="mb-4">
                        <label asp-for="ImageFile" class="form-label iocl-form-label">Replace Image (optional)</label>
                        <input asp-for="ImageFile" type="file" class="form-control iocl-form-control" accept="image/*" />
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold">Facility is Active (visible for booking)</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save-fill me-2"></i>Save Changes
                        </button>
                        <a href="/Facility/Index" class="btn btn-light border px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm p-4 border-warning" style="border-left: 4px solid #ffc107 !important;">
            <h6 class="fw-bold text-dark mb-2"><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Important Note</h6>
            <p class="small text-muted mb-0">
                Changing the <strong>Rental Rate</strong> only affects <em>new</em> bookings going forward.
                Existing bookings retain the rate that was locked in at the time of their submission (<code>RateAtBooking</code>).
            </p>
        </div>
    </div>
</div>
