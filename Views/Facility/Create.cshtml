@model IOCLCommunityHall.Models.ViewModels.HallViewModel
@using IOCLCommunityHall.Models.Entities
@{
    ViewData["Title"] = "Add New Facility";
    ViewData["PageTitle"] = "Add New Facility";
    ViewData["Breadcrumb"] = "<li class=\"breadcrumb-item\"><a href=\"/Facility/Index\">Facilities</a></li><li class=\"breadcrumb-item active\">Add New</li>";
}

<div class="row">
    <div class="col-lg-8">
        <div class="card iocl-card shadow-sm">
            <div class="card-header iocl-card-header bg-white border-bottom">
                <span class="fw-bold text-dark">
                    <i class="bi bi-plus-circle-fill me-2 text-primary"></i>New Bookable Facility
                </span>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <div class="row mb-3">
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label iocl-form-label"></label>
                            <input asp-for="Name" class="form-control iocl-form-control" placeholder="e.g. Main Community Hall" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FacilityType" class="form-label iocl-form-label"></label>
                            <select asp-for="FacilityType" class="form-select iocl-form-control"
                                    asp-items="Html.GetEnumSelectList<IOCLCommunityHall.Models.Entities.FacilityType>()">
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label iocl-form-label"></label>
                        <textarea asp-for="Description" class="form-control iocl-form-control" rows="2"
                                  placeholder="Brief description of the facility and its purpose"></textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-8">
                            <label asp-for="Location" class="form-label iocl-form-label"></label>
                            <input asp-for="Location" class="form-control iocl-form-control" placeholder="e.g. IOCL Township Community Centre, Sector A" />
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Capacity" class="form-label iocl-form-label"></label>
                            <input asp-for="Capacity" type="number" class="form-control iocl-form-control" placeholder="e.g. 500" min="1" />
                            <span asp-validation-for="Capacity" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Facilities" class="form-label iocl-form-label"></label>
                        <input asp-for="Facilities" class="form-control iocl-form-control"
                               placeholder="Air Conditioning, Sound System, Stage, Projector (comma separated)" />
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="RentalRatePerDay" class="form-label iocl-form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                <input asp-for="RentalRatePerDay" type="number" class="form-control iocl-form-control" placeholder="5000" step="100" min="0" />
                            </div>
                            <span asp-validation-for="RentalRatePerDay" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label iocl-form-label"></label>
                            <select asp-for="Status" class="form-select iocl-form-control"
                                    asp-items="Html.GetEnumSelectList<IOCLCommunityHall.Models.Entities.HallStatus>()">
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DisplayOrder" class="form-label iocl-form-label"></label>
                            <input asp-for="DisplayOrder" type="number" class="form-control iocl-form-control" placeholder="0 = first" min="0" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ImageFile" class="form-label iocl-form-label"></label>
                        <input asp-for="ImageFile" type="file" class="form-control iocl-form-control" accept="image/*" />
                        <div class="form-text text-muted">Optional. Upload a photo of the facility (JPG, PNG, WebP). Max 5MB recommended.</div>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                        <label asp-for="IsActive" class="form-check-label fw-semibold">Facility is Active (visible for booking)</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-plus-circle-fill me-2"></i>Create Facility
                        </button>
                        <a href="/Facility/Index" class="btn btn-light border px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm p-4">
            <h6 class="fw-bold text-dark mb-3"><i class="bi bi-lightbulb-fill text-warning me-2"></i>Facility Types</h6>
            <ul class="list-unstyled small text-muted mb-0" style="line-height:1.8;">
                <li><i class="bi bi-building-fill text-primary me-2"></i><strong>MainHall</strong> – Primary multipurpose hall</li>
                <li><i class="bi bi-cup-hot-fill text-warning me-2"></i><strong>DiningHall</strong> – Catering & dining space</li>
                <li><i class="bi bi-tree-fill text-success me-2"></i><strong>OpenGround</strong> – Outdoor event space</li>
                <li><i class="bi bi-flower1 text-pink me-2"></i><strong>Garden</strong> – Landscaped garden area</li>
                <li><i class="bi bi-music-note-beamed text-purple me-2"></i><strong>CulturalStage</strong> – Performance stage</li>
                <li><i class="bi bi-briefcase-fill text-secondary me-2"></i><strong>ConferenceHall</strong> – Formal conference room</li>
                <li><i class="bi bi-people-fill text-info me-2"></i><strong>MeetingRoom</strong> – Small meeting space</li>
            </ul>
        </div>
    </div>
</div>
