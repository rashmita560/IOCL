@model IEnumerable<IOCLCommunityHall.Models.Entities.RentalRequest>
@using IOCLCommunityHall.Models.Entities
@inject IOCLCommunityHall.Data.ApplicationDbContext DbContext
@{
    ViewData["Title"] = "Rental Request Approvals";
    var fcfsQueue = ViewBag.FCFSQueue as IEnumerable<IOCLCommunityHall.Models.Entities.RentalRequest>;
    var currentRole = ViewBag.CurrentRole as string ?? "SuperAdmin";
    var roleLabel = currentRole == "HOD" ? "HOD Approvals" : currentRole == "GM" ? "GM Approvals" : "All Rental Requests";

    string GetHODDisplayName(string dept)
    {
        var hodRole = DbContext.Roles.FirstOrDefault(r => r.Name == "HOD");
        if (hodRole == null) return "";
        var hodUser = !string.IsNullOrEmpty(dept) ? DbContext.Users.FirstOrDefault(u => u.Department == dept && 
            DbContext.UserRoles.Any(ur => ur.UserId == u.Id && ur.RoleId == hodRole.Id)) : null;
        if (hodUser == null)
        {
            hodUser = DbContext.Users.FirstOrDefault(u => 
                DbContext.UserRoles.Any(ur => ur.UserId == u.Id && ur.RoleId == hodRole.Id));
        }
        if (hodUser == null) return "";
        return hodUser.EmployeeId;
    }

    string GetGMDisplayName()
    {
        var gmRole = DbContext.Roles.FirstOrDefault(r => r.Name == "GM");
        if (gmRole == null) return "20000001";
        var gmUser = DbContext.Users.FirstOrDefault(u => 
            DbContext.UserRoles.Any(ur => ur.UserId == u.Id && ur.RoleId == gmRole.Id));
        return gmUser?.EmployeeId ?? "20000001";
    }

    string GetHRDisplayName()
    {
        var hrRole = DbContext.Roles.FirstOrDefault(r => r.Name == "SuperAdmin");
        if (hrRole == null) return "00000001";
        var hrUser = DbContext.Users.FirstOrDefault(u => 
            DbContext.UserRoles.Any(ur => ur.UserId == u.Id && ur.RoleId == hrRole.Id));
        return hrUser?.EmployeeId ?? "00000001";
    }

    string GetUserDisplayNameByEmpId(string empId)
    {
        if (string.IsNullOrEmpty(empId)) return "";
        if (empId == "SYSTEM") return "SYSTEM";
        var user = DbContext.Users.FirstOrDefault(u => u.EmployeeId == empId || u.UserName == empId);
        if (user != null)
        {
            var roles = DbContext.UserRoles.Where(ur => ur.UserId == user.Id).Select(ur => ur.RoleId).ToList();
            var roleNames = DbContext.Roles.Where(r => roles.Contains(r.Id)).Select(r => r.Name).ToList();
            var designation = "Employee";
            if (roleNames.Contains("SuperAdmin")) designation = "HR";
            else if (roleNames.Contains("GM")) designation = "GM";
            else if (roleNames.Contains("HOD")) designation = "HOD";
            return $"{designation} - {user.EmployeeId}";
        }
        if (empId.StartsWith("3")) return $"HOD - {empId}";
        if (empId.StartsWith("2")) return $"GM - {empId}";
        if (empId.StartsWith("0")) return $"HR - {empId}";
        return $"Employee - {empId}";
    }

    string StageBadge(RentalRequest r)
    {
        if (r.Status == RequestStatus.Cancelled)
        {
            return "<span class=\"badge bg-secondary text-white iocl-badge\">Cancelled</span>";
        }
        if (r.Status == RequestStatus.Returned)
        {
            return "<span class=\"badge iocl-badge\" style=\"background:#198754;color:#fff;\"><i class=\"bi bi-arrow-return-left me-1\"></i>Returned</span>";
        }
        return r.ApprovalStage switch {
            ApprovalStage.PendingHOD => $"<span class=\"badge badge-pending iocl-badge\">Pending to HOD ({GetHODDisplayName(r.User?.Department)})</span>",
            ApprovalStage.PendingGM  => $"<span class=\"badge badge-pending iocl-badge\">Pending to GM ({GetGMDisplayName()})</span>",
            ApprovalStage.PendingHR  => $"<span class=\"badge badge-pending iocl-badge\">Pending to HR ({GetHRDisplayName()})</span>",
            ApprovalStage.Approved   => "<span class=\"badge badge-approved iocl-badge\">Approved</span>",
            ApprovalStage.Rejected   => $"<span class=\"badge badge-rejected iocl-badge\">{(string.IsNullOrEmpty(r.ReviewedByEmployeeId) ? "Rejected" : $"Rejected by {GetUserDisplayNameByEmpId(r.ReviewedByEmployeeId)}")}</span>",
            _ => r.ApprovalStage.ToString()
        };
    }
}

<!-- FCFS Queue Main List Layout (Full Width) -->
<div class="row">
    <!-- Main Request List (Full Width) -->
    <div class="col-lg-12">
        <div class="card iocl-card shadow-sm">
            <div class="card-header iocl-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-card-checklist me-2 text-primary"></i>@roleLabel</span>
                @if (currentRole != "SuperAdmin") {
                    <span class="badge bg-secondary ms-2" style="font-size:0.75rem;">Showing requests assigned to your stage</span>
                }
            </div>
            <div class="card-body">
                <!-- Search & Filters -->
                <form method="get" class="row g-3 mb-4">
                    <div class="col-md-5">
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                            <input type="text" name="search" class="form-control iocl-form-control" placeholder="Search by number, event, name..." value="@ViewBag.Search" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <select name="statusFilter" class="form-select iocl-form-control">
                            <option value="All">All Statuses</option>
                            @foreach (var val in new[] { RequestStatus.Pending, RequestStatus.Approved, RequestStatus.Rejected })
                            {
                                <option value="@val" selected="@(ViewBag.StatusFilter == val.ToString())">@val.ToString()</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-iocl-blue w-100">Apply Filter</button>
                    </div>
                </form>

                <!-- Requests Table -->
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                @if (ViewBag.StatusFilter == "Pending")
                                {
                                    <th>Priority</th>
                                }
                                <th>Request ID</th>
                                <th>Employee / Dept</th>
                                <th>Event Date</th>
                                <th>Grand Total</th>
                                <th>Stage</th>
                                <th>Status</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var req in Model)
                                {
                                    <tr>
                                        @if (ViewBag.StatusFilter == "Pending")
                                        {
                                            var rankDict = ViewBag.RankDict as System.Collections.Generic.Dictionary<int, int>;
                                            var rank = rankDict != null && rankDict.ContainsKey(req.Id) ? rankDict[req.Id] : 0;
                                            <td>
                                                <div class="fw-bold text-success" style="font-size: 1.05rem; margin-bottom: 2px;">#@rank</div>
                                                <div class="small text-muted" style="white-space: nowrap; font-size: 0.82rem; margin-bottom: 2px;">@req.CreatedAt.ToString("dd-MMM-yyyy")</div>
                                                <div class="small text-muted" style="white-space: nowrap; font-size: 0.82rem;">@req.CreatedAt.ToString("HH:mm:ss")</div>
                                            </td>
                                        }
                                        <td class="fw-bold text-primary">#@req.RequestNumber</td>
                                        <td>
                                            <div class="fw-bold text-dark">@req.User?.FullName</div>
                                            <span class="text-muted small">@req.User?.Department</span>
                                            @if (!string.IsNullOrEmpty(req.SubmittedByRole) && req.SubmittedByRole != "User") {
                                                <span class="badge bg-secondary-subtle text-secondary" style="font-size:0.7rem;">@req.SubmittedByRole</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="fw-bold">@req.EventDate.ToString("dd MMM yyyy")</div>
                                            <span class="text-muted small" style="font-size:0.75rem;">@req.StartDate.ToString("dd/MM") to @req.EndDate.ToString("dd/MM")</span>
                                        </td>
                                        <td class="fw-bold">₹@req.GrandTotal</td>
                                        <td>@Html.Raw(StageBadge(req))</td>
                                        <td>
                                            @if (req.Status == RequestStatus.Pending)
                                            {
                                                <span class="badge badge-pending iocl-badge">
                                                    @(req.ApprovalStage == ApprovalStage.PendingHOD ? $"PENDING TO HOD ({GetHODDisplayName(req.User?.Department)})" : 
                                                      req.ApprovalStage == ApprovalStage.PendingGM ? $"PENDING TO GM ({GetGMDisplayName()})" : 
                                                      req.ApprovalStage == ApprovalStage.PendingHR ? $"PENDING TO HR ({GetHRDisplayName()})" : "PENDING")
                                                </span>
                                            }
                                            else if (req.Status == RequestStatus.Approved)
                                            {
                                                <span class="badge badge-approved iocl-badge">APPROVED</span>
                                            }
                                            else if (req.Status == RequestStatus.Cancelled)
                                            {
                                                <span class="badge bg-secondary text-white iocl-badge">CANCELLED</span>
                                            }
                                            else if (req.Status == RequestStatus.Returned)
                                            {
                                                <span class="badge iocl-badge" style="background:#198754;color:#fff;">
                                                    <i class="bi bi-arrow-return-left me-1"></i>RETURNED
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-rejected iocl-badge">
                                                    @(string.IsNullOrEmpty(req.ReviewedByEmployeeId) ? "REJECTED" : $"Rejected by {GetUserDisplayNameByEmpId(req.ReviewedByEmployeeId)}")
                                                </span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <a asp-action="Details" asp-route-id="@req.Id" class="btn btn-sm btn-primary">
                                                <i class="bi bi-clipboard-check"></i> Review
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="@(ViewBag.StatusFilter == "Pending" ? 8 : 7)" class="text-center text-muted py-4">No matching rental requests found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
