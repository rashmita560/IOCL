@model IEnumerable<IOCLCommunityHall.Models.Entities.HallBooking>
@using IOCLCommunityHall.Models.Entities
@{
    ViewData["Title"] = "Manage Hall Bookings";
    ViewData["PageTitle"] = "Hall Booking Requests";
}

<div class="row">
    <div class="col-12">
        <div class="card iocl-card shadow-sm">
            <div class="card-header iocl-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-building me-2 text-primary"></i>All Township Hall Booking Requests</span>
                <span class="badge bg-secondary">@Model.Count() Bookings</span>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Booking ID</th>
                                <th>Facilities</th>
                                <th>Event Details / Requester</th>
                                <th>Date & Time Slot</th>
                                <th>Rental Fee</th>
                                <th>Mode</th>
                                <th>Status</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var b in Model)
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold text-primary">#CHB-@b.Id</td>
                                        <td>
                                            @{
                                                var facNames = b.BookingFacilities != null && b.BookingFacilities.Any()
                                                    ? string.Join(" + ", b.BookingFacilities.Select(bf => bf.Facility?.Name ?? "—"))
                                                    : "—";
                                            }
                                            <div class="fw-bold text-dark">@facNames</div>
                                            @if (b.BookingMode == BookingMode.Combined)
                                            {
                                                <span class="badge bg-info-subtle text-info border border-info-subtle" style="font-size:0.7rem;">Combined</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="fw-bold text-dark">@b.EventName</div>
                                            <span class="text-muted small">Requested by: @b.User?.FullName (@b.User?.Department)</span>
                                        </td>
                                        <td>
                                            <div><i class="bi bi-calendar-event me-1 text-muted"></i>@b.EventDate.ToString("dd MMM yyyy")</div>
                                            <span class="text-muted small"><i class="bi bi-clock me-1"></i>@b.StartTime.ToString(@"hh\:mm") to @b.EndTime.ToString(@"hh\:mm")</span>
                                        </td>
                                        <td class="fw-bold text-success">₹@b.TotalAmount.ToString("N0")</td>
                                        <td>
                                            @if (b.BookingMode == BookingMode.Combined)
                                            {
                                                <span class="badge bg-primary-subtle text-primary border">Combined</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-secondary border">Single</span>
                                            }
                                        </td>
                                        <td>
                                            @if (b.Status == BookingStatus.Pending)
                                            {
                                                <span class="badge badge-pending iocl-badge">Pending</span>
                                            }
                                            else if (b.Status == BookingStatus.Approved)
                                            {
                                                <span class="badge badge-approved iocl-badge">Approved</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-rejected iocl-badge">Rejected</span>
                                                @if (!string.IsNullOrEmpty(b.RejectionReason))
                                                {
                                                    <div class="small text-danger" style="font-size:0.75rem;">Reason: @b.RejectionReason</div>
                                                }
                                            }
                                        </td>
                                        <td class="text-end pe-3">
                                            @if (b.Status == BookingStatus.Pending)
                                            {
                                                <div class="d-inline-flex gap-1">
                                                    <!-- Approve Form -->
                                                    <form asp-action="ApproveHallBooking" asp-route-id="@b.Id" method="post" onsubmit="return confirm('Approve this hall booking?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-success">
                                                            <i class="bi bi-check-lg"></i> Approve
                                                        </button>
                                                    </form>
                                                    
                                                    <!-- Reject Button Triggering Collapse/Reason -->
                                                    <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="collapse" data-bs-target="#rejectForm-@b.Id">
                                                        <i class="bi bi-x-lg"></i> Reject
                                                    </button>
                                                </div>

                                                <!-- Rejection Reason Input Collapsed Row -->
                                                <div class="collapse mt-2" id="rejectForm-@b.Id">
                                                    <form asp-action="RejectHallBooking" asp-route-id="@b.Id" method="post" class="bg-light p-2 rounded border text-start" style="min-width: 250px;">
                                                        @Html.AntiForgeryToken()
                                                        <div class="mb-2">
                                                            <label class="form-label small fw-bold">Rejection Reason</label>
                                                            <textarea name="reason" class="form-control form-control-sm" rows="2" placeholder="Reason..." required></textarea>
                                                        </div>
                                                        <button type="submit" class="btn btn-xs btn-danger w-100">Confirm Reject</button>
                                                    </form>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">No action required</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-4 text-muted">No hall bookings found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
