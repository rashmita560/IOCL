@model IOCLCommunityHall.Models.Entities.RentalRequest
@using IOCLCommunityHall.Models.Entities
@inject IOCLCommunityHall.Data.ApplicationDbContext DbContext
@{
    ViewData["Title"] = "Request Details";
    var hasStockConflict = false;
    var currentUserId = ViewBag.CurrentUserId as string ?? "";
    var currentRole = ViewBag.CurrentRole as string ?? "";
    var isSelfRequest = ViewBag.IsSelfRequest is bool b && b;

    string GetHODDisplayName(string dept)
    {
        var hodRole = DbContext.Roles.FirstOrDefault(r => r.Name == "HOD");
        if (hodRole == null) return "";
        var hodUser = !string.IsNullOrEmpty(dept) ? DbContext.Users.FirstOrDefault(u => u.Department == dept && 
            DbContext.UserRoles.Any(ur => ur.UserId == u.Id && ur.RoleId == hodRole.Id)) : null;
        if (hodUser == null)
        {
            hodUser = DbContext.Users.FirstOrDefault(u => 
                DbContext.UserRoles.Any(ur => ur.UserId == u.Id && ur.RoleId == hodRole.Id));
        }
        return hodUser != null ? $"{hodUser.FullName} - {hodUser.EmployeeId}" : "";
    }

    string GetUserDisplayNameByEmpId(string empId)
    {
        if (string.IsNullOrEmpty(empId)) return "";
        if (empId == "SYSTEM") return "SYSTEM";
        var user = DbContext.Users.FirstOrDefault(u => u.EmployeeId == empId || u.UserName == empId);
        return user != null ? $"{user.FullName} - {user.EmployeeId}" : empId;
    }

    // Determine if the current user can approve at the current stage
    bool canApprove = !isSelfRequest &&
                      Model.Status == RequestStatus.Pending &&
                      ((currentRole == "HOD" && Model.ApprovalStage == ApprovalStage.PendingHOD) ||
                       (currentRole == "GM" && Model.ApprovalStage == ApprovalStage.PendingGM) ||
                       (currentRole == "SuperAdmin" && Model.ApprovalStage == ApprovalStage.PendingHR));

    // Stage label helper
    string stageLabel(ApprovalStage s) => s switch {
        ApprovalStage.PendingHOD => "Pending HOD",
        ApprovalStage.PendingGM  => "Pending GM",
        ApprovalStage.PendingHR  => "Pending HR",
        ApprovalStage.Approved   => "Approved",
        ApprovalStage.Rejected   => "Rejected",
        _ => s.ToString()
    };
}

<div class="row">
    <div class="col-lg-8">
        <!-- Main request details -->
        <div class="card iocl-card shadow-sm mb-4">
            <div class="card-header iocl-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-file-earmark-text-fill me-2 text-primary"></i>Rental Request #@Model.RequestNumber</span>
                <span class="badge @(Model.Status == RequestStatus.Pending ? "badge-pending" : Model.Status == RequestStatus.Approved ? "badge-approved" : "badge-rejected") iocl-badge">
                    @(Model.Status == RequestStatus.Pending ? 
                      (Model.ApprovalStage == ApprovalStage.PendingHOD ? $"Pending to HOD ({GetHODDisplayName(Model.User?.Department)})" : 
                       Model.ApprovalStage == ApprovalStage.PendingGM ? "Pending to GM" : 
                       Model.ApprovalStage == ApprovalStage.PendingHR ? "Pending to HR" : "Pending") : 
                      (Model.Status == RequestStatus.Rejected ? 
                       (string.IsNullOrEmpty(Model.ReviewedByEmployeeId) ? "Rejected" : $"Rejected by {GetUserDisplayNameByEmpId(Model.ReviewedByEmployeeId)}") : 
                       Model.Status.ToString()))
                </span>
            </div>
            <div class="card-body p-4">
                <div class="row mb-4 pb-3 border-bottom">
                    <div class="col-md-6">
                        <div class="text-muted small">REQUESTER DETAILS</div>
                        <h5 class="fw-bold text-dark mb-1">@Model.User?.FullName</h5>
                        <div class="text-muted small">Emp ID: @Model.User?.EmployeeId | Dept: @Model.User?.Department</div>
                        <div class="text-muted small">Quarter: @Model.User?.Employee?.QuarterAddress</div>
                        <div class="mt-1">
                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle" style="font-size:0.75rem;">
                                Submitted as: @Model.SubmittedByRole
                            </span>
                        </div>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <div class="text-muted small">RENTAL DETAILS</div>
                        <div class="text-muted small">Event Date: @Model.EventDate.ToString("dd MMM yyyy")</div>
                        <div class="text-muted small">Rental Period: @Model.StartDate.ToString("dd/MM/yyyy") to @Model.EndDate.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.InPrincipalDocumentPath))
                {
                    <div class="mb-4 p-3 bg-light rounded border">
                        <div class="text-muted small fw-bold mb-2">IN-PRINCIPAL APPROVAL DOCUMENT</div>
                        <a href="@Model.InPrincipalDocumentPath" target="_blank" class="btn btn-primary btn-sm">
                            <i class="bi bi-file-earmark-text me-1"></i>View / Verify In-Principal Document
                        </a>
                    </div>
                }

                <!-- Approval Trail -->
                <div class="mb-4 p-3 rounded border" style="background:#f8f9ff;">
                    <div class="text-muted small fw-bold mb-3"><i class="bi bi-diagram-3 me-1 text-primary"></i>APPROVAL TRAIL</div>
                    <div class="d-flex flex-wrap gap-2 align-items-center">

                        @* HOD Stage *@
                        @if (Model.SubmittedByRole == "User")
                        {
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(Model.HODApprovedByEmployeeId))
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2" title="@Model.HODApprovedAt?.ToString("dd MMM yyyy HH:mm")">
                                        <i class="bi bi-check-circle-fill me-1"></i>HOD: @GetUserDisplayNameByEmpId(Model.HODApprovedByEmployeeId)
                                    </span>
                                }
                                else if (Model.ApprovalStage == ApprovalStage.PendingHOD && Model.Status == RequestStatus.Pending)
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2">
                                        <i class="bi bi-hourglass-split me-1"></i>HOD: Pending (Emp: @GetHODDisplayName(Model.User?.Department))
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2">
                                        <i class="bi bi-dash-circle me-1"></i>HOD: N/A
                                    </span>
                                }
                                <i class="bi bi-chevron-right text-muted"></i>
                            </div>
                        }

                        @* GM Stage *@
                        @if (Model.SubmittedByRole == "User" || Model.SubmittedByRole == "SuperAdmin" ||
                             (Model.SubmittedByRole == "HOD" && Model.GrandTotal > 10000))
                        {
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(Model.GMApprovedByEmployeeId))
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2" title="@Model.GMApprovedAt?.ToString("dd MMM yyyy HH:mm")">
                                        <i class="bi bi-check-circle-fill me-1"></i>GM: @GetUserDisplayNameByEmpId(Model.GMApprovedByEmployeeId)
                                    </span>
                                }
                                else if (Model.ApprovalStage == ApprovalStage.PendingGM && Model.Status == RequestStatus.Pending)
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2">
                                        <i class="bi bi-hourglass-split me-1"></i>GM: Pending
                                    </span>
                                }
                                else if (Model.ApprovalStage == ApprovalStage.PendingHOD)
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2">
                                        <i class="bi bi-clock me-1"></i>GM: Queued
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2">
                                        <i class="bi bi-dash-circle me-1"></i>GM: N/A
                                    </span>
                                }
                                @if (Model.GrandTotal <= 10000 || Model.SubmittedByRole == "GM")
                                {
                                    <i class="bi bi-chevron-right text-muted"></i>
                                }
                            </div>
                        }

                        @* HR Stage *@
                        @if (Model.GrandTotal <= 10000 || Model.SubmittedByRole == "GM")
                        {
                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrEmpty(Model.HRApprovedByEmployeeId))
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2" title="@Model.HRApprovedAt?.ToString("dd MMM yyyy HH:mm")">
                                        <i class="bi bi-check-circle-fill me-1"></i>HR: @GetUserDisplayNameByEmpId(Model.HRApprovedByEmployeeId)
                                    </span>
                                }
                                else if (Model.Status == RequestStatus.Rejected)
                                {
                                    <span class="badge bg-danger px-3 py-2">
                                        <i class="bi bi-x-circle-fill me-1"></i>Rejected
                                    </span>
                                }
                                else if (Model.ApprovalStage == ApprovalStage.PendingHR && Model.Status == RequestStatus.Pending)
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2">
                                        <i class="bi bi-hourglass-split me-1"></i>HR: Pending
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2">
                                        <i class="bi bi-clock me-1"></i>HR: Queued
                                    </span>
                                }
                            </div>
                        }
                    </div>
                    <div class="mt-2 text-muted" style="font-size:0.78rem;">
                        Current Stage: <strong>@stageLabel(Model.ApprovalStage)</strong>
                    </div>
                    @if (Model.Status == RequestStatus.Approved && !string.IsNullOrEmpty(Model.ReviewedByEmployeeId))
                    {
                        <div class="mt-1 text-muted" style="font-size:0.78rem;">
                            Final Approver: <strong>@GetUserDisplayNameByEmpId(Model.ReviewedByEmployeeId)</strong> (Approved At: @Model.ReviewedAt?.ToString("dd MMM yyyy HH:mm"))
                        </div>
                    }
                    @if (Model.Status == RequestStatus.Rejected && !string.IsNullOrEmpty(Model.ReviewedByEmployeeId))
                    {
                        <div class="mt-1 text-muted" style="font-size:0.78rem;">
                            Rejected By: <strong>@GetUserDisplayNameByEmpId(Model.ReviewedByEmployeeId)</strong> (Rejected At: @Model.ReviewedAt?.ToString("dd MMM yyyy HH:mm"))
                        </div>
                    }
                </div>

                <h5 class="fw-bold text-dark border-bottom pb-2 mb-3"><i class="bi bi-box-seam me-2 text-primary"></i>Requested Items</h5>

                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Item Name</th>
                            <th class="text-end">Daily Rate</th>
                            <th class="text-center">Requested Qty</th>
                            <th class="text-end">Line Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.RentalRequestItems)
                        {
                            var available = item.InventoryItem?.AvailableQuantity ?? 0;
                            var conflict = item.RequestedQuantity > available;
                            if (conflict) { hasStockConflict = true; }

                            <tr>
                                <td class="fw-bold">@item.InventoryItem?.Name</td>
                                <td class="text-end">₹@item.UnitPriceAtRequest</td>
                                <td class="text-center">@item.RequestedQuantity</td>
                                <td class="text-end fw-bold">₹@((item.RequestedQuantity * item.UnitPriceAtRequest).ToString("F2"))</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="text-end mt-4">
                    <h4 class="fw-bold">Grand Total: <span style="color: var(--iocl-orange);">₹@Model.GrandTotal</span></h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Administrative Actions Sidebar -->
    <div class="col-lg-4">
        <div class="card iocl-card shadow-sm border-0 bg-white p-4">
            <h5 class="fw-bold text-dark mb-3"><i class="bi bi-gear-wide-connected text-primary me-2"></i>
                @if (currentRole == "HOD") { <text>HOD Decision</text> }
                else if (currentRole == "GM") { <text>GM Decision</text> }
                else { <text>HR Final Decision</text> }
            </h5>

            @if (isSelfRequest)
            {
                <div class="alert alert-warning border-0 py-3 mb-3">
                    <i class="bi bi-shield-exclamation me-2"></i>
                    <strong>Self-Request</strong><br />
                    <small>You submitted this request. You cannot approve your own requests.</small>
                </div>
            }

            @if (canApprove)
            {
                if (hasStockConflict)
                {
                    <div class="alert alert-warning small mb-3">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Stock Warning:</strong> One or more requested items have insufficient quantity. Approving may partially allocate.
                    </div>
                }

                <div class="d-grid gap-2">
                    <!-- Approve Action -->
                    <form asp-action="Approve" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Approve this request and advance to next stage?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success w-100 py-2">
                            <i class="bi bi-check-circle-fill me-2"></i>Approve &amp; Advance
                        </button>
                    </form>

                    <!-- Reject Action Modal Trigger -->
                    <button type="button" class="btn btn-danger w-100 py-2" data-bs-toggle="modal" data-bs-target="#rejectModal">
                        <i class="bi bi-x-circle-fill me-2"></i>Reject Request
                    </button>
                </div>
            }
            else if (!isSelfRequest && Model.Status == RequestStatus.Pending)
            {
                <div class="alert alert-secondary py-3 text-center mb-0">
                    <i class="bi bi-hourglass-split me-1"></i>
                    This request is at stage <strong>@stageLabel(Model.ApprovalStage)</strong>.<br />
                    <small class="text-muted">It is not yet at your approval stage.</small>
                </div>
            }
            else
            {
                <div class="alert alert-secondary py-3 text-center mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    This request has been <strong>@Model.Status.ToString().ToUpper()</strong>.
                </div>
            }

            @if (Model.Status == RequestStatus.Rejected && !string.IsNullOrEmpty(Model.RejectionReason))
            {
                <div class="mt-3 p-3 bg-danger-subtle rounded border border-danger-subtle">
                    <div class="text-muted small fw-bold mb-1">REJECTION REASON</div>
                    <div class="small text-danger">@Model.RejectionReason</div>
                </div>
            }

            <hr class="my-4" />
            <a asp-action="Index" class="btn btn-light border w-100">Back to Requests List</a>
        </div>
    </div>
</div>

<!-- Reject Reason Dialog Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Reject" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title fw-bold text-dark"><i class="bi bi-x-circle-fill text-danger me-2"></i>Reject Request</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label for="rejectionReason" class="form-label iocl-form-label">Reason for Rejection</label>
                        <textarea class="form-control iocl-form-control" name="reason" id="rejectionReason" rows="4" placeholder="e.g. Insufficient stock, budget exceeded, missing documents..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Submit Rejection</button>
                </div>
            </form>
        </div>
    </div>
</div>
