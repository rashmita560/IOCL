@model IEnumerable<IOCLCommunityHall.Models.Entities.CommunityHall>
@using IOCLCommunityHall.Models.Entities
@{
    ViewData["Title"] = "Community Hall Booking";
    ViewData["PageTitle"] = "Facility Booking";
    var myBookings = ViewBag.MyBookings as IEnumerable<IOCLCommunityHall.Models.Entities.HallBooking>;
}

<!-- ── Facilities Overview ────────────────────────────────────── -->
<div class="row mb-4">
    <div class="col-12 mb-3">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h4 class="fw-bold text-dark mb-1">
                    <i class="bi bi-houses-fill me-2 text-primary"></i>IOCL Township – Bookable Facilities
                </h4>
                <p class="text-muted small mb-0">Select one or more facilities and submit a booking request.</p>
            </div>
            <a asp-action="Create" class="btn btn-primary px-4">
                <i class="bi bi-calendar-plus-fill me-2"></i>New Booking Request
            </a>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        foreach (var facility in Model)
        {
            var iconClass = facility.FacilityType == FacilityType.MainHall ? "bi-building-fill" :
                            facility.FacilityType == FacilityType.DiningHall ? "bi-cup-hot-fill" :
                            facility.FacilityType == FacilityType.OpenGround ? "bi-tree-fill" :
                            facility.FacilityType == FacilityType.ConferenceHall ? "bi-briefcase-fill" :
                            facility.FacilityType == FacilityType.MeetingRoom ? "bi-people-fill" : "bi-geo-fill";
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm border-0 iocl-card" style="border-radius:16px;overflow:hidden;">
                    @if (!string.IsNullOrEmpty(facility.ImagePath))
                    {
                        <img src="@facility.ImagePath" class="card-img-top" alt="@facility.Name"
                             style="height: 180px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center flex-column bg-light border-bottom"
                             style="height: 160px;">
                            <i class="bi @iconClass text-primary" style="font-size:2.5rem;opacity:0.5;"></i>
                            <span class="text-muted small mt-2">@facility.FacilityType.ToString()</span>
                        </div>
                    }
                    <div class="card-body d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0 text-dark">@facility.Name</h5>
                            <span class="badge @(facility.Status == HallStatus.Available ? "bg-success" : "bg-warning text-dark")">
                                @facility.Status.ToString()
                            </span>
                        </div>
                        <p class="text-muted small mb-3">@facility.Description</p>
                        <ul class="list-unstyled small text-muted mb-4">
                            <li class="mb-1"><i class="bi bi-geo-alt-fill text-danger me-2"></i><strong>Location:</strong> @facility.Location</li>
                            <li class="mb-1"><i class="bi bi-people-fill text-primary me-2"></i><strong>Capacity:</strong> @facility.Capacity persons</li>
                            <li class="mb-1"><i class="bi bi-cash-stack text-success me-2"></i><strong>Rate:</strong> ₹@facility.RentalRatePerDay.ToString("N0") / day</li>
                        </ul>
                        <a asp-action="Create" asp-route-facilityId="@facility.Id"
                           class="btn btn-primary w-100 mt-auto py-2">
                            <i class="bi bi-calendar-event-fill me-2"></i>Book This Facility
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="bi bi-houses fs-1"></i>
            <p class="mt-2">No facilities configured. Contact Super Admin to add bookable facilities.</p>
        </div>
    }
</div>

<!-- ── My Bookings History ─────────────────────────────────────── -->
<div class="card iocl-card shadow-sm">
    <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between">
        <span class="fw-bold text-dark">
            <i class="bi bi-calendar-check-fill me-2 text-primary"></i>My Booking History
        </span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Booking ID</th>
                        <th>Facilities Booked</th>
                        <th>Event Name</th>
                        <th>Date &amp; Time</th>
                        <th>Total Cost</th>
                        <th>Mode</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (myBookings != null && myBookings.Any())
                    {
                        foreach (var booking in myBookings)
                        {
                            var facilityNames = booking.BookingFacilities != null
                                ? string.Join(" + ", booking.BookingFacilities.Select(bf => bf.Facility?.Name ?? "—"))
                                : "—";
                            <tr>
                                <td class="ps-4 fw-bold text-primary">#CHB-@booking.Id</td>
                                <td>
                                    <div class="fw-semibold text-dark">@facilityNames</div>
                                    @if (booking.BookingMode == BookingMode.Combined)
                                    {
                                        <span class="badge bg-info-subtle text-info border border-info-subtle" style="font-size:0.7rem;">Combined</span>
                                    }
                                </td>
                                <td>
                                    <div class="fw-bold">@booking.EventName</div>
                                    <span class="text-muted small">@booking.EventType.ToString()</span>
                                </td>
                                <td>
                                    <i class="bi bi-calendar-date me-1 text-muted"></i>@booking.EventDate.ToString("dd MMM yyyy")
                                    <div class="text-muted small">
                                        <i class="bi bi-clock me-1"></i>@booking.StartTime.ToString(@"hh\:mm") – @booking.EndTime.ToString(@"hh\:mm")
                                    </div>
                                </td>
                                <td class="fw-bold text-success">₹@booking.TotalAmount.ToString("N0")</td>
                                <td>
                                    @if (booking.BookingMode == BookingMode.Combined)
                                    {
                                        <span class="badge bg-primary-subtle text-primary border">Combined</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-secondary border">Single</span>
                                    }
                                </td>
                                <td>
                                    @if (booking.Status == BookingStatus.Pending)
                                    {
                                        <span class="badge badge-pending iocl-badge">Pending</span>
                                    }
                                    else if (booking.Status == BookingStatus.Approved)
                                    {
                                        <span class="badge badge-approved iocl-badge">Approved</span>
                                    }
                                    else if (booking.Status == BookingStatus.Rejected)
                                    {
                                        <span class="badge badge-rejected iocl-badge">Rejected</span>
                                        @if (!string.IsNullOrEmpty(booking.RejectionReason))
                                        {
                                            <div class="small text-danger" style="font-size:0.75rem;">@booking.RejectionReason</div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary iocl-badge">Cancelled</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <button type="button" class="btn btn-sm btn-light border" onclick="window.print()">
                                        <i class="bi bi-printer-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>
                                You have no hall bookings yet.
                                <div class="mt-2">
                                    <a asp-action="Create" class="btn btn-sm btn-primary">Make a Booking</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
