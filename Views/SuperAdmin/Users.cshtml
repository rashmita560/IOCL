@model IEnumerable<(IOCLCommunityHall.Models.Entities.ApplicationUser User, System.Collections.Generic.IList<string> Roles, IOCLCommunityHall.Models.Entities.Employee Employee)>
@using IOCLCommunityHall.Models.Entities
@{
    ViewData["Title"] = "User & Access Management";
    ViewData["PageTitle"] = "User Management";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-3" role="alert"
         style="border-left:4px solid #16a34a !important;">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-3" role="alert"
         style="border-left:4px solid #dc2626 !important;">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-12">
        <div class="card iocl-card shadow-sm">
            <div class="card-header iocl-card-header d-flex justify-content-between align-items-center">
                <span>
                    <i class="bi bi-people-fill me-2 text-primary"></i>
                    Township Employee Accounts
                    <span class="badge bg-secondary ms-2">@Model.Count() Total</span>
                </span>
                <a asp-controller="SuperAdmin" asp-action="CreateUser" class="btn btn-sm btn-primary">
                    <i class="bi bi-person-plus-fill me-1"></i>Add Employee Account
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size:0.87rem;">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" style="width:110px;">Emp ID</th>
                                <th>Employee Name</th>
                                <th>Department</th>
                                <th>Designation</th>
                                <th>Email</th>
                                <th style="width:110px;">Role</th>
                                <th class="text-center" style="width:90px;">Status</th>
                                <th style="width:130px;">Last Login</th>
                                <th class="text-end pe-3" style="width:200px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in Model)
                            {
                                var user = entry.User;
                                var emp = entry.Employee;
                                var roles = entry.Roles;
                                var currentRole = roles.FirstOrDefault() ?? "User";
                                var roleBadgeClass = currentRole switch {
                                    "SuperAdmin" => "badge-role-superadmin",
                                    "GM"         => "badge-role-gm",
                                    "HOD"        => "badge-role-hod",
                                    _            => "badge-role-user"
                                };
                                var roleColor = currentRole switch {
                                    "SuperAdmin" => "#dc2626",
                                    "GM"         => "#7c3aed",
                                    "HOD"        => "#2563eb",
                                    _            => "#6b7280"
                                };

                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold" style="font-size:0.88rem; font-family: monospace; color: #1e3a8a;">@user.EmployeeId</span>
                                    </td>
                                    <td>
                                        <div class="fw-semibold text-dark">@(emp?.EmployeeName ?? user.FullName)</div>
                                    </td>
                                    <td class="text-muted">@(emp?.Department ?? user.Department)</td>
                                    <td class="text-muted">@(emp?.Designation ?? "—")</td>
                                    <td class="text-muted" style="font-size:0.82rem;">@(emp?.Email ?? user.Email)</td>
                                    <td>
                                        <span class="@roleBadgeClass">@currentRole</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(user.IsActive ? "bg-success-subtle text-success border border-success-subtle" : "bg-danger-subtle text-danger border border-danger-subtle")"
                                              style="font-size:0.75rem;">
                                            @(user.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="text-muted" style="font-size:0.78rem;">
                                        @(user.LastLoginAt.HasValue ? user.LastLoginAt.Value.ToLocalTime().ToString("dd MMM yy, HH:mm") : "Never")
                                    </td>
                                    <td class="text-end pe-3">
                                        <div class="d-inline-flex gap-1 flex-wrap justify-content-end">

                                            <!-- Edit -->
                                            <a asp-action="EditUser" asp-route-userId="@user.Id"
                                               class="btn btn-xs btn-outline-secondary" title="Edit employee details">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>

                                            <!-- Change Role Dropdown -->
                                            <div class="dropdown">
                                                <button class="btn btn-xs btn-outline-primary dropdown-toggle" type="button"
                                                        data-bs-toggle="dropdown" title="Change role">
                                                    <i class="bi bi-shield-fill me-1"></i>Role
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                                    <li><span class="dropdown-header small text-muted">Assign Role</span></li>
                                                    @foreach (var r in new[] { "User", "HOD", "GM", "SuperAdmin" })
                                                    {
                                                        var rColor = r switch {
                                                            "SuperAdmin" => "#dc2626",
                                                            "GM"         => "#7c3aed",
                                                            "HOD"        => "#2563eb",
                                                            _            => "#6b7280"
                                                        };
                                                        <li>
                                                            <form asp-action="ChangeRole" method="post">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="userId" value="@user.Id" />
                                                                <input type="hidden" name="newRole" value="@r" />
                                                                <button type="submit"
                                                                        class="dropdown-item @(currentRole == r ? "active" : "")">
                                                                    <i class="bi bi-circle-fill me-1"
                                                                       style="font-size:0.5rem;vertical-align:middle;color:@rColor"></i>
                                                                    @r @(currentRole == r ? "✓" : "")
                                                                </button>
                                                            </form>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>


                                            <!-- Activate / Deactivate -->
                                            <form asp-action="ToggleActive" method="post" class="d-inline"
                                                  onsubmit="return confirm('@(user.IsActive ? "Deactivate" : "Activate") account for @(emp?.EmployeeName ?? user.FullName)?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit"
                                                        class="btn btn-xs @(user.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                                                        title="@(user.IsActive ? "Deactivate" : "Activate") account">
                                                    <i class="bi bi-@(user.IsActive ? "person-slash-fill" : "person-check-fill")"></i>
                                                    @(user.IsActive ? "Deactivate" : "Activate")
                                                </button>
                                            </form>

                                            <!-- Reset Password -->
                                            <button type="button" class="btn btn-xs btn-outline-warning"
                                                    title="Reset password"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#resetPwdModal"
                                                    onclick="prepResetModal('@user.Id', '@(emp?.EmployeeName ?? user.FullName)', '@user.EmployeeId')">
                                                <i class="bi bi-key-fill"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal fade" id="resetPwdModal" tabindex="-1" aria-labelledby="resetPwdLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content border-0 shadow-lg" style="border-radius:14px;">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold" id="resetPwdLabel">
                    <i class="bi bi-key-fill text-warning me-2"></i>Reset Password
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <p class="text-muted small mb-3" id="resetPwdInfo">Resetting password for employee.</p>
                    <input type="hidden" name="userId" id="resetUserId" />
                    <label class="form-label fw-semibold small">New Password</label>
                    <input type="password" name="newPassword" class="form-control"
                           placeholder="Min. 6 characters" minlength="6" required autocomplete="new-password" />
                    <div class="form-text text-muted">Must be at least 6 characters.</div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning fw-bold">
                        <i class="bi bi-key-fill me-1"></i>Reset Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function prepResetModal(userId, empName, empId) {
        document.getElementById('resetUserId').value = userId;
        document.getElementById('resetPwdInfo').textContent =
            'Resetting password for: ' + empName + ' (ID: ' + empId + ')';
    }
</script>
