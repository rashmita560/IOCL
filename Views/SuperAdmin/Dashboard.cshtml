@{
    ViewData["Title"] = "SuperAdmin Control Panel";
}

<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center" role="alert">
            <i class="bi bi-shield-fill-exclamation fs-4 me-3"></i>
            <div>
                <strong>SuperAdmin Restricted Zone</strong> &mdash; This area provides full system access including user management, role assignment, and system configuration.
                All actions are permanently logged in the audit trail.
            </div>
        </div>
    </div>
</div>

<!-- KPI Summary Row -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card iocl-stat-card shadow-sm h-100 border-0" style="border-left: 4px solid var(--iocl-orange) !important;">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-uppercase small fw-bold text-muted mb-1">Total Users</p>
                        <h2 class="fw-bold mb-0 text-dark">@(ViewBag.TotalUsers ?? 0)</h2>
                    </div>
                    <div class="iocl-stat-icon" style="background: rgba(255,107,0,0.12); color: var(--iocl-orange);">
                        <i class="bi bi-people-fill"></i>
                    </div>
                </div>
                <small class="text-muted">Registered portal accounts</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card iocl-stat-card shadow-sm h-100 border-0" style="border-left: 4px solid var(--iocl-blue) !important;">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-uppercase small fw-bold text-muted mb-1">Active Admins</p>
                        <h2 class="fw-bold mb-0 text-dark">@(ViewBag.AdminCount ?? 0)</h2>
                    </div>
                    <div class="iocl-stat-icon" style="background: rgba(0,82,136,0.12); color: var(--iocl-blue);">
                        <i class="bi bi-person-badge-fill"></i>
                    </div>
                </div>
                <small class="text-muted">Administrators &amp; SuperAdmins</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card iocl-stat-card shadow-sm h-100 border-0" style="border-left: 4px solid #28a745 !important;">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-uppercase small fw-bold text-muted mb-1">Inventory Items</p>
                        <h2 class="fw-bold mb-0 text-dark">@(ViewBag.InventoryCount ?? 0)</h2>
                    </div>
                    <div class="iocl-stat-icon" style="background: rgba(40,167,69,0.12); color: #28a745;">
                        <i class="bi bi-boxes"></i>
                    </div>
                </div>
                <small class="text-muted">Active inventory items in catalogue</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card iocl-stat-card shadow-sm h-100 border-0" style="border-left: 4px solid #dc3545 !important;">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-uppercase small fw-bold text-muted mb-1">Audit Log Entries</p>
                        <h2 class="fw-bold mb-0 text-dark">@(ViewBag.AuditCount ?? 0)</h2>
                    </div>
                    <div class="iocl-stat-icon" style="background: rgba(220,53,69,0.12); color: #dc3545;">
                        <i class="bi bi-journal-text"></i>
                    </div>
                </div>
                <small class="text-muted">Total audit trail records</small>
            </div>
        </div>
    </div>
</div>

<!-- Control Panel Quick Access -->
<div class="row g-4">
    <!-- User Management -->
    <div class="col-lg-4">
        <div class="card iocl-card shadow-sm h-100">
            <div class="card-header iocl-card-header text-white" style="background: var(--iocl-orange);">
                <i class="bi bi-people-fill me-2"></i>User &amp; Access Management
            </div>
            <div class="card-body p-4">
                <p class="text-muted small mb-3">Manage all portal users: create accounts, assign roles (User / Admin / SuperAdmin), activate or deactivate accounts.</p>
                <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                        <span>Total Registered Users</span>
                        <strong class="text-primary">@(ViewBag.TotalUsers ?? 0)</strong>
                    </li>
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                        <span>Active Accounts</span>
                        <strong class="text-success">@(ViewBag.ActiveUsers ?? 0)</strong>
                    </li>
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                        <span>Disabled Accounts</span>
                        <strong class="text-danger">@(ViewBag.DisabledUsers ?? 0)</strong>
                    </li>
                </ul>
                <a asp-controller="SuperAdmin" asp-action="Users" class="btn btn-primary w-100">
                    <i class="bi bi-arrow-right-circle me-2"></i>Manage Users
                </a>
            </div>
        </div>
    </div>

    <!-- System Settings -->
    <div class="col-lg-4">
        <div class="card iocl-card shadow-sm h-100">
            <div class="card-header iocl-card-header text-white" style="background: var(--iocl-blue);">
                <i class="bi bi-gear-fill me-2"></i>System Configuration
            </div>
            <div class="card-body p-4">
                <p class="text-muted small mb-3">Manage pricing rules, inventory categories, hall configurations, and application-level settings.</p>
                <div class="d-grid gap-2">
                    <a asp-controller="Inventory" asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-boxes me-2"></i>Inventory Management
                    </a>
                    <a asp-controller="Price" asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-currency-rupee me-2"></i>Pricing Rules &amp; History
                    </a>
                    <a asp-controller="AdminDashboard" asp-action="Halls" class="btn btn-outline-primary">
                        <i class="bi bi-buildings me-2"></i>Community Halls Setup
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Audit Trail -->
    <div class="col-lg-4">
        <div class="card iocl-card shadow-sm h-100">
            <div class="card-header iocl-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-shield-lock-fill me-2 text-danger"></i>Audit Trail</span>
                <a asp-controller="Audit" asp-action="Index" class="btn btn-sm btn-outline-secondary">View All</a>
            </div>
            <div class="card-body p-4">
                <p class="text-muted small mb-3">All administrative actions are permanently recorded. View the full immutable activity log for compliance and security.</p>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                        <span>Today's Entries</span>
                        <strong class="text-info">@(ViewBag.TodayAuditCount ?? 0)</strong>
                    </li>
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                        <span>This Week</span>
                        <strong>@(ViewBag.WeekAuditCount ?? 0)</strong>
                    </li>
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between">
                        <span>Total Lifetime Logs</span>
                        <strong>@(ViewBag.AuditCount ?? 0)</strong>
                    </li>
                </ul>
                <a asp-controller="Audit" asp-action="Index" class="btn btn-outline-danger w-100 mt-3">
                    <i class="bi bi-journal-code me-2"></i>Open Audit Logs
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Recent User Registrations -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card iocl-card shadow-sm">
            <div class="card-header iocl-card-header">
                <i class="bi bi-person-lines-fill me-2"></i>Recent User Registrations
            </div>
            <div class="card-body p-0">
                @if (ViewBag.RecentUsers != null)
                {
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Full Name</th>
                                <th>Email</th>
                                <th>Employee ID</th>
                                <th>Department</th>
                                <th>Registered On</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in ViewBag.RecentUsers)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold">@u.FullName</td>
                                    <td class="text-muted small">@u.Email</td>
                                    <td>@u.EmployeeId</td>
                                    <td>@u.Department</td>
                                    <td class="text-muted small">@u.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td class="text-center">
                                        <span class="badge @(u.IsActive ? "bg-success" : "bg-secondary")">
                                            @(u.IsActive ? "Active" : "Disabled")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-4 text-center text-muted">No recent user registrations found.</div>
                }
            </div>
        </div>
    </div>
</div>
