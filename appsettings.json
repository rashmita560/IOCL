{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=iocl_community_hall.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
